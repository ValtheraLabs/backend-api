APP_NAME=Valthera Backend API
APP_ENV=local
APP_VERSION=0.2.0
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AI_ENGINE_BASE_URL=http://localhost:8001
AI_ENGINE_TIMEOUT_SECONDS=5
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite:///./valthera.db
LOG_LEVEL=INFO
QUOTE_CACHE_TTL=10
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
ZEROX_API_KEY=
ONEINCH_API_KEY=
WEB3_RPC_URL_1=https://eth-mainnet.g.alchemy.com/v2/demo
